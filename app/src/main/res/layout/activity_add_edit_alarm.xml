<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nouvelle alarme"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nom de la personne"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="32dp"
        android:id="@+id/lblName"
        app:layout_constraintTop_toBottomOf="@id/tvHeader"
        app:layout_constraintStart_toStartOf="parent" />

    <EditText
        android:id="@+id/etName"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:hint="ex: Papa, Moi, Rina..."
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:background="@drawable/bg_input"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="textPersonName|textCapWords"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/lblName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/lblInterval"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Intervalle entre chaque alarme"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/etName"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvIntervalValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="3 heures"
        android:textColor="@color/accent"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/lblInterval"
        app:layout_constraintStart_toStartOf="parent" />

    <SeekBar
        android:id="@+id/seekInterval"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="23"
        android:progress="2"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvIntervalValue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Glissez pour choisir de 1h à 24h"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/seekInterval"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:text="Enregistrer"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="@color/bg_dark"
        android:textStyle="bold"
        android:background="@drawable/bg_button_accent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>